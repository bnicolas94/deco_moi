---
import AdminLayout from '@/layouts/AdminLayout.astro';
import { db } from '@/lib/db/connection';
import { products, categories } from '@/lib/db/schema';
import { eq, desc, asc, and, like, or } from 'drizzle-orm';
import { Plus, Pencil, Trash2, Search, Filter, Package, ExternalLink, MoreVertical } from 'lucide-react';

const search = Astro.url.searchParams.get('q') || '';
const categoryFilter = Astro.url.searchParams.get('category') || '';
const statusFilter = Astro.url.searchParams.get('status') || '';
const sortBy = Astro.url.searchParams.get('sort') || 'name_asc';

const filters = [];
if (search) {
    filters.push(or(like(products.name, `%${search}%`), like(products.sku, `%${search}%`)));
}
if (categoryFilter) {
    filters.push(eq(products.categoryId, parseInt(categoryFilter)));
}
if (statusFilter === 'active') {
    filters.push(eq(products.isActive, true));
} else if (statusFilter === 'inactive') {
    filters.push(eq(products.isActive, false));
}

let orderByClause = asc(products.name);
if (sortBy === 'newest') orderByClause = desc(products.createdAt);
if (sortBy === 'name_desc') orderByClause = desc(products.name);
if (sortBy === 'price_asc') orderByClause = asc(products.basePrice);
if (sortBy === 'price_desc') orderByClause = desc(products.basePrice);
if (sortBy === 'stock_asc') orderByClause = asc(products.stock);
if (sortBy === 'stock_desc') orderByClause = desc(products.stock);
if (sortBy === 'category_asc') orderByClause = asc(categories.name);
if (sortBy === 'category_desc') orderByClause = desc(categories.name);
if (sortBy === 'status_asc') orderByClause = asc(products.isActive);
if (sortBy === 'status_desc') orderByClause = desc(products.isActive);

const allProducts = await db
    .select({
        id: products.id,
        name: products.name,
        sku: products.sku,
        price: products.basePrice,
        stock: products.stock,
        category: categories.name,
        categoryId: categories.id,
        isActive: products.isActive,
        image: products.images,
        slug: products.slug,
    })
    .from(products)
    .leftJoin(categories, eq(products.categoryId, categories.id))
    .where(filters.length > 0 ? and(...filters) : undefined)
    .orderBy(orderByClause);

const allCategories = await db.select().from(categories).orderBy(categories.name);
---

<AdminLayout title="Productos">
    <div class="mb-8 flex flex-col md:flex-row justify-between items-start md:items-center gap-4">
        <div class="flex flex-col">
            <h1 class="text-3xl font-extrabold text-gray-900 tracking-tight">Productos</h1>
            <p class="text-gray-500 mt-1 font-medium">Gestiona tu catálogo completo y niveles de stock.</p>
        </div>
        
        <!-- Bulk Actions Bar -->
        <div id="bulk-actions-bar" class="hidden flex-1 mx-4 p-4 bg-indigo-50 border border-indigo-100 rounded-2xl flex items-center justify-between animate-in fade-in slide-in-from-top-4">
            <div class="flex items-center gap-4">
                <span class="text-sm font-bold text-indigo-900">
                    <span id="selected-count">0</span> seleccionados
                </span>
                <div class="h-6 w-px bg-indigo-200"></div>
                <div class="flex items-center gap-2">
                    <button onclick="handleBulkAction('activate')" class="px-4 py-2 bg-white text-indigo-600 border border-indigo-200 text-xs font-bold rounded-xl hover:bg-indigo-100 transition-all">Activar</button>
                    <button onclick="handleBulkAction('deactivate')" class="px-4 py-2 bg-white text-indigo-600 border border-indigo-200 text-xs font-bold rounded-xl hover:bg-indigo-100 transition-all">Desactivar</button>
                    <button onclick="handleBulkAction('delete')" class="px-4 py-2 bg-rose-50 text-rose-600 border border-rose-100 text-xs font-bold rounded-xl hover:bg-rose-100 transition-all">Eliminar</button>
                </div>
            </div>
            <button onclick="clearSelection()" class="text-gray-400 hover:text-gray-600">
                <Plus className="w-5 h-5 rotate-45" />
            </button>
        </div>
        <a 
            href="/admin/products/new" 
            class="inline-flex items-center px-5 py-2.5 bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-bold rounded-xl shadow-lg shadow-indigo-100 transition-all transform active:scale-95"
        >
            <Plus className="w-5 h-5 mr-1.5" />
            Nuevo Producto
        </a>
    </div>

    <!-- Enhanced Filters & Search -->
    <div class="bg-white p-4 rounded-2xl shadow-sm border border-gray-100 mb-8 flex flex-col md:flex-row gap-4">
        <form action="/admin/products" method="GET" class="flex-1 flex flex-col md:flex-row gap-4 items-center">
            <div class="relative flex-1 w-full">
                <div class="absolute inset-y-0 left-0 pl-3.5 flex items-center pointer-events-none text-gray-400">
                    <Search className="h-4 w-4" />
                </div>
                <input 
                    type="text" 
                    name="q"
                    value={search}
                    placeholder="Buscar por nombre o SKU..." 
                    class="pl-10 block w-full rounded-xl border-gray-200 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm h-11 border transition-all"
                />
            </div>
            
            <div class="flex flex-col md:flex-row gap-2 w-full md:w-auto">
                <select 
                    name="category" 
                    class="block w-full md:w-48 rounded-xl border-gray-200 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm h-11 border px-3 bg-white font-medium"
                    onchange="this.form.submit()"
                >
                    <option value="">Todas las categorías</option>
                    {allCategories.map(cat => (
                        <option value={cat.id} selected={categoryFilter === cat.id.toString()}>
                            {cat.name}
                        </option>
                    ))}
                </select>

                <select 
                    name="status" 
                    class="block w-full md:w-48 rounded-xl border-gray-200 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm h-11 border px-3 bg-white font-medium"
                    onchange="this.form.submit()"
                >
                    <option value="">Todos los estados</option>
                    <option value="active" selected={statusFilter === 'active'}>Activos</option>
                    <option value="inactive" selected={statusFilter === 'inactive'}>Inactivos</option>
                </select>
                
                <button type="submit" class="md:hidden inline-flex items-center px-4 py-2 bg-gray-900 text-white rounded-xl">
                    Buscar
                </button>
            </div>
        </form>
    </div>

    <!-- Products Table -->
    <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
        <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-gray-100">
                <thead>
                    <tr class="bg-gray-50/50">
                        <th class="px-6 py-4 text-left text-xs font-bold text-gray-400 uppercase tracking-widest">
                            <div class="flex items-center gap-2">
                                <span class="checkbox-container mr-2">
                                    <input type="checkbox" id="select-all" class="rounded border-gray-300 text-indigo-600 focus:ring-indigo-500 cursor-pointer" />
                                </span>
                                Producto
                                <div class="flex flex-col ml-1">
                                    <a href={`/admin/products?q=${search}&category=${categoryFilter}&status=${statusFilter}&sort=name_asc`} class={`hover:text-indigo-600 ${sortBy === 'name_asc' ? 'text-indigo-600' : ''}`}><svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="m18 15-6-6-6 6"/></svg></a>
                                    <a href={`/admin/products?q=${search}&category=${categoryFilter}&status=${statusFilter}&sort=name_desc`} class={`hover:text-indigo-600 ${sortBy === 'name_desc' ? 'text-indigo-600' : ''}`}><svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg></a>
                                </div>
                            </div>
                        </th>
                        <th class="px-6 py-4 text-left text-xs font-bold text-gray-400 uppercase tracking-widest">
                            <div class="flex items-center gap-1">
                                Categoría
                                <div class="flex flex-col ml-1">
                                    <a href={`/admin/products?q=${search}&category=${categoryFilter}&status=${statusFilter}&sort=category_asc`} class={`hover:text-indigo-600 ${sortBy === 'category_asc' ? 'text-indigo-600' : ''}`}><svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="m18 15-6-6-6 6"/></svg></a>
                                    <a href={`/admin/products?q=${search}&category=${categoryFilter}&status=${statusFilter}&sort=category_desc`} class={`hover:text-indigo-600 ${sortBy === 'category_desc' ? 'text-indigo-600' : ''}`}><svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg></a>
                                </div>
                            </div>
                        </th>
                        <th class="px-6 py-4 text-left text-xs font-bold text-gray-400 uppercase tracking-widest">
                            <div class="flex items-center gap-1">
                                Precio
                                <div class="flex flex-col ml-1">
                                    <a href={`/admin/products?q=${search}&category=${categoryFilter}&status=${statusFilter}&sort=price_asc`} class={`hover:text-indigo-600 ${sortBy === 'price_asc' ? 'text-indigo-600' : ''}`}><svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="m18 15-6-6-6 6"/></svg></a>
                                    <a href={`/admin/products?q=${search}&category=${categoryFilter}&status=${statusFilter}&sort=price_desc`} class={`hover:text-indigo-600 ${sortBy === 'price_desc' ? 'text-indigo-600' : ''}`}><svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg></a>
                                </div>
                            </div>
                        </th>
                        <th class="px-6 py-4 text-left text-xs font-bold text-gray-400 uppercase tracking-widest">
                            <div class="flex items-center gap-1">
                                Stock
                                <div class="flex flex-col ml-1">
                                    <a href={`/admin/products?q=${search}&category=${categoryFilter}&status=${statusFilter}&sort=stock_asc`} class={`hover:text-indigo-600 ${sortBy === 'stock_asc' ? 'text-indigo-600' : ''}`}><svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="m18 15-6-6-6 6"/></svg></a>
                                    <a href={`/admin/products?q=${search}&category=${categoryFilter}&status=${statusFilter}&sort=stock_desc`} class={`hover:text-indigo-600 ${sortBy === 'stock_desc' ? 'text-indigo-600' : ''}`}><svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg></a>
                                </div>
                            </div>
                        </th>
                        <th class="px-6 py-4 text-left text-xs font-bold text-gray-400 uppercase tracking-widest">
                            <div class="flex items-center gap-1">
                                Estado
                                <div class="flex flex-col ml-1">
                                    <a href={`/admin/products?q=${search}&category=${categoryFilter}&status=${statusFilter}&sort=status_asc`} class={`hover:text-indigo-600 ${sortBy === 'status_asc' ? 'text-indigo-600' : ''}`}><svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="m18 15-6-6-6 6"/></svg></a>
                                    <a href={`/admin/products?q=${search}&category=${categoryFilter}&status=${statusFilter}&sort=status_desc`} class={`hover:text-indigo-600 ${sortBy === 'status_desc' ? 'text-indigo-600' : ''}`}><svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg></a>
                                </div>
                            </div>
                        </th>
                        <th class="relative px-6 py-4"></th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-50 bg-white">
                    {allProducts.length === 0 ? (
                        <tr>
                            <td colspan="6" class="px-6 py-20 text-center">
                                <div class="flex flex-col items-center justify-center">
                                    <div class="p-4 bg-gray-50 rounded-full mb-4">
                                        <Package className="w-10 h-10 text-gray-300" />
                                    </div>
                                    <p class="text-gray-500 font-medium">No se encontraron productos.</p>
                                    <p class="text-sm text-gray-400 mt-1">Intenta con otros términos o filtros.</p>
                                    { (search || categoryFilter) && (
                                        <a href="/admin/products" class="mt-4 text-indigo-600 font-bold text-sm hover:underline">Limpiar Filtros</a>
                                    )}
                                </div>
                            </td>
                        </tr>
                    ) : (
                        allProducts.map((product) => (
                            <tr class="hover:bg-gray-50/50 transition-colors group">
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <div class="flex items-center underline-none">
                                        <div class="flex items-center gap-3">
                                            <div class="checkbox-container">
                                                <input type="checkbox" name="product-select" value={product.id} class="product-checkbox rounded border-gray-300 text-indigo-600 focus:ring-indigo-500" />
                                            </div>
                                            <div class="h-12 w-12 rounded-xl border border-gray-100 shadow-sm overflow-hidden group-hover:scale-105 transition-transform bg-gray-50 flex items-center justify-center flex-shrink-0">
                                                {product.image && product.image[0] ? (
                                                    <img class="h-full w-full object-cover" src={product.image[0]} alt="" />
                                                ) : (
                                                    <Package className="h-6 w-6 text-gray-300" />
                                                )}
                                            </div>
                                        </div>
                                        <div class="ml-4">
                                            <div class="text-sm font-bold text-gray-900 line-clamp-1">{product.name}</div>
                                            <div class="text-[10px] font-mono text-gray-400 tracking-tighter uppercase mt-0.5">{product.sku || 'Sin SKU'}</div>
                                        </div>
                                    </div>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <span class="px-3 py-1 inline-flex text-xs font-bold leading-5 rounded-lg bg-indigo-50 text-indigo-700 border border-indigo-100">
                                        {product.category || 'Sin categoría'}
                                    </span>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900 font-extrabold tracking-tight">
                                    ${parseFloat(product.price).toLocaleString(undefined, { minimumFractionDigits: 2 })}
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <div class="flex items-center">
                                        <span class={`text-sm font-bold ${product.stock <= 5 ? 'text-rose-600' : 'text-gray-600'}`}>
                                            {product.stock}
                                        </span>
                                        {product.stock <= 5 && (
                                            <span class="ml-1.5 flex h-1.5 w-1.5 rounded-full bg-rose-500 animate-pulse"></span>
                                        )}
                                    </div>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <span class={`px-2.5 py-1 inline-flex text-[10px] font-black uppercase tracking-widest rounded-full border ${product.isActive ? 'bg-emerald-50 text-emerald-700 border-emerald-100' : 'bg-rose-50 text-rose-700 border-rose-100'}`}>
                                        {product.isActive ? 'Activo' : 'Inactivo'}
                                    </span>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                                    <div class="flex items-center justify-end gap-1">
                                        <a href={`/producto/${product.slug}`} target="_blank" class="p-2 text-gray-400 hover:text-indigo-600 hover:bg-gray-100 rounded-lg transition-all" title="Ver en tienda">
                                            <ExternalLink className="w-4 h-4" />
                                        </a>
                                        <a href={`/admin/products/${product.id}`} class="p-2 text-indigo-600 hover:bg-indigo-50 rounded-lg transition-all" title="Editar">
                                            <Pencil className="w-4 h-4" />
                                        </a>
                                        <button class="p-2 text-rose-600 hover:bg-rose-50 rounded-lg transition-all" onclick={`confirmDelete(${product.id})`} title="Eliminar">
                                            <Trash2 className="w-4 h-4" />
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        ))
                    )}
                </tbody>
            </table>
        </div>
    </div>

    <!-- Pagination (Placeholder) -->
    <div class="mt-4 flex items-center justify-between">
        <div class="flex-1 flex justify-between sm:hidden">
            <a href="#" class="relative inline-flex items-center px-4 py-2 border border-gray-300 text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50">
                Anterior
            </a>
            <a href="#" class="ml-3 relative inline-flex items-center px-4 py-2 border border-gray-300 text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50">
                Siguiente
            </a>
        </div>
        <div class="hidden sm:flex-1 sm:flex sm:items-center sm:justify-between">
            <div>
                <p class="text-sm text-gray-700">
                    Mostrando <span class="font-medium">1</span> a <span class="font-medium">{allProducts.length}</span> de <span class="font-medium">{allProducts.length}</span> resultados
                </p>
            </div>
            <div>
                <nav class="relative z-0 inline-flex rounded-md shadow-sm -space-x-px" aria-label="Pagination">
                    <!-- Pagination links -->
                </nav>
            </div>
        </div>
    </div>
</AdminLayout>

<script is:inline>
    function confirmDelete(id) {
        if (confirm('¿Estás seguro de que deseas eliminar este producto?')) {
            // Implement delete logic (POST to API)
            fetch(`/api/products/${id}`, { method: 'DELETE' })
                .then(() => window.location.reload())
                .catch(err => alert('Error al eliminar'));
        }
    }

    // Bulk Actions Selection
    const selectAll = document.getElementById('select-all');
    const productCheckboxes = document.querySelectorAll('.product-checkbox');
    const bulkBar = document.getElementById('bulk-actions-bar');
    const selectedCount = document.getElementById('selected-count');

    function updateBulkBar() {
        const checkedCount = document.querySelectorAll('.product-checkbox:checked').length;
        if (checkedCount > 0) {
            bulkBar.classList.remove('hidden');
            bulkBar.classList.add('flex');
            selectedCount.textContent = checkedCount;
        } else {
            bulkBar.classList.add('hidden');
            bulkBar.classList.remove('flex');
        }
        
        if (selectAll) {
            selectAll.checked = checkedCount === productCheckboxes.length && productCheckboxes.length > 0;
        }
    }

    selectAll?.addEventListener('change', (e) => {
        productCheckboxes.forEach(cb => {
            cb.checked = e.target.checked;
        });
        updateBulkBar();
    });

    productCheckboxes.forEach(cb => {
        cb.addEventListener('change', updateBulkBar);
    });

    function clearSelection() {
        productCheckboxes.forEach(cb => cb.checked = false);
        if (selectAll) selectAll.checked = false;
        updateBulkBar();
    }

    async function handleBulkAction(action) {
        const selectedIds = Array.from(document.querySelectorAll('.product-checkbox:checked')).map(cb => parseInt(cb.value));
        if (selectedIds.length === 0) return;

        let confirmMsg = `¿Estás seguro de aplicar esta acción a ${selectedIds.length} productos?`;
        if (action === 'delete') confirmMsg = `¿ESTÁS SEGURO? Se eliminarán permanentemente ${selectedIds.length} productos. Esta acción no tiene vuelta atrás.`;

        if (confirm(confirmMsg)) {
            try {
                const response = await fetch('/api/products/bulk', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ ids: selectedIds, action })
                });

                if (response.ok) {
                    window.location.reload();
                } else {
                    const data = await response.json();
                    alert('Error: ' + (data.error || 'Ocurrió un error inesperado'));
                }
            } catch (e) {
                alert('Error de red al realizar la acción masiva');
            }
        }
    }
</script>
