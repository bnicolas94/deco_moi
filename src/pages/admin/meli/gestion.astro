---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { db } from '../../../lib/db/connection';
import { products } from '../../../lib/db/schema';
import { eq, desc } from 'drizzle-orm';

// Cargar catálogo local para el datalist (selector de productos)
const allProducts = await db
  .select({
    id: products.id,
    name: products.name,
    sku: products.sku,
  })
  .from(products)
  .orderBy(desc(products.createdAt));

---

<style is:global>
  /* Estilos para el switch de toggle */
  .form-switch {
    position: relative;
    display: inline-flex;
    cursor: pointer;
    -webkit-user-select: none;
    -moz-user-select: none;
    -ms-user-select: none;
    user-select: none;
  }
  .form-switch label {
    display: block;
    width: 44px;
    height: 24px;
    border-radius: 9999px;
    transition: background-color 0.15s ease-in-out;
  }
  .form-switch input:checked + label {
    background-color: #4f46e5;
  }
  .form-switch input:checked + label span {
    transform: translateX(20px);
  }
  .form-switch label span {
    position: absolute;
    top: 2px;
    left: 2px;
    width: 20px;
    height: 20px;
    border-radius: 9999px;
    transition: transform 0.15s ease-in-out;
    box-shadow: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
  }
</style>

<AdminLayout title="Gestión Externa MercadoLibre">
  <div class="px-4 sm:px-6 lg:px-8 py-8 w-full max-w-9xl mx-auto">
    <div class="sm:flex sm:justify-between sm:items-center mb-8">
      <div class="mb-4 sm:mb-0">
        <h1 class="text-2xl md:text-3xl text-slate-800 dark:text-slate-100 font-bold">
          Gestor de Publicaciones ML Externas
        </h1>
        <p class="text-sm text-slate-500 mt-1">Vincula o sobreescribe productos de tu catálogo a tus ítems ya creados en Mercado Libre.</p>
      </div>
      <div class="flex gap-2">
         <a href="/admin/meli" class="btn bg-white dark:bg-slate-800 border-slate-200 dark:border-slate-700 hover:border-slate-300 dark:hover:border-slate-600">Volver al Dashboard</a>
      </div>
    </div>

    <!-- Filtros -->
    <div class="mb-4 sm:flex items-center justify-between gap-4">
      <div class="flex flex-col sm:flex-row items-center gap-4 flex-grow">
        <div class="relative w-full sm:w-80">
          <input id="searchInput" class="form-input w-full pl-9" type="search" placeholder="Buscar publicación de ML..." />
          <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none text-slate-400">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
          </div>
        </div>
        
        <!-- Toggle Mostrar Pausados -->
        <div class="flex items-center">
            <div class="form-switch">
                <input type="checkbox" id="showPaused" class="sr-only" />
                <label class="bg-slate-400 dark:bg-slate-700" for="showPaused">
                    <span class="bg-white" aria-hidden="true"></span>
                    <span class="sr-only">Mostrar Pausados</span>
                </label>
            </div>
            <div class="text-sm text-slate-400 font-medium ml-2 uppercase tracking-wider text-[10px]">Mostrar Pausados</div>
        </div>
      </div>

      <div class="flex items-center gap-2 mt-4 sm:mt-0">
         <button id="btnReload" class="btn bg-white dark:bg-slate-800 border-slate-200 dark:border-slate-700 text-slate-600 dark:text-slate-400 hover:border-slate-300 shadow-sm transition-all">
            <span id="reloadText" class="text-xs font-bold uppercase tracking-wider">Recargar Listado</span>
         </button>
      </div>
    </div>

    <div class="bg-white dark:bg-slate-800 shadow-lg rounded-sm border border-slate-200 dark:border-slate-700 relative">
      <div class="overflow-x-auto">
        <table class="table-auto w-full dark:text-slate-300" id="listingsTable">
          <thead class="text-xs font-semibold uppercase text-slate-500 dark:text-slate-400 bg-slate-50 dark:bg-slate-900 border-t border-b border-slate-200 dark:border-slate-700">
            <tr>
              <th class="px-2 first:pl-5 last:pr-5 py-3 whitespace-nowrap w-16"><div class="font-semibold text-center">Img</div></th>
              <th class="px-2 first:pl-5 last:pr-5 py-3 whitespace-normal min-w-48"><div class="font-semibold text-left">Publicación en ML</div></th>
              <th class="px-2 first:pl-5 last:pr-5 py-3 whitespace-nowrap"><div class="font-semibold text-center">Estado ML</div></th>
              <th class="px-2 first:pl-5 last:pr-5 py-3 whitespace-nowrap"><div class="font-semibold text-left">Vinculación (Catálogo Local)</div></th>
              <th class="px-2 first:pl-5 last:pr-5 py-3 whitespace-nowrap"><div class="font-semibold text-right">Inversión Final</div></th>
              <th class="px-2 first:pl-5 last:pr-5 py-3 whitespace-nowrap"><div class="font-semibold text-center">Acciones</div></th>
            </tr>
          </thead>
          <tbody id="listingsBody" class="text-sm divide-y divide-slate-200 dark:divide-slate-700">
            <tr>
              <td colspan="6" class="px-2 py-8 text-center text-slate-500">
                Cargando publicaciones...
              </td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</AdminLayout>

<script is:inline define:vars={{ allProducts }}>
  let allItems = [];
  const listingsBody = document.getElementById('listingsBody');
  const searchInput = document.getElementById('searchInput');
  const btnReload = document.getElementById('btnReload');
  const reloadText = document.getElementById('reloadText');

  async function loadListings(query = '') {
    listingsBody.innerHTML = `
      <tr>
        <td colspan="6" class="px-2 py-8 text-center text-slate-500">
          <svg class="animate-spin h-6 w-6 mx-auto mb-2 text-indigo-500" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
          </svg>
          ${query ? `Buscando "${query}"...` : 'Trayendo catálogo desde MercadoLibre...'}
        </td>
      </tr>
    `;
    reloadText.innerText = query ? 'Buscando...' : 'Cargando...';
    btnReload.disabled = true;

    try {
      const url = new URL('/api/meli/listings', window.location.origin);
      url.searchParams.set('limit', '100');
      if (query) url.searchParams.set('q', query);
      
      const res = await fetch(url);
      const data = await res.json();
      if (data.success) {
        allItems = data.items;
        renderItems(allItems);
      } else {
        listingsBody.innerHTML = `<tr><td colspan="6" class="px-2 py-4 text-center text-rose-500">Error: ${data.error}</td></tr>`;
      }
    } catch (e) {
      listingsBody.innerHTML = `<tr><td colspan="6" class="px-2 py-4 text-center text-rose-500">Error de red al cargar publicaciones.</td></tr>`;
    } finally {
      reloadText.innerText = 'Recargar Listado';
      btnReload.disabled = false;
    }
  }

  function normalizeTitle(title) {
    // 1. Quitar sufijo de cantidad (ej: " (10u)", " x 20", " - 5 unid")
    let t = title.replace(/\s*\(\d+u\)$/i, '');
    t = t.replace(/\s*x\s*\d+$/i, '');
    t = t.replace(/\s*-\s*\d+\s*unid.*$/i, '');
    
    // 2. Quitar prefijo de cantidad (ej: "10 ", "25x ", "100 unidades de ")
    t = t.replace(/^\d+\s*( unidades de |x\s*| )/i, '');
    
    return t.trim();
  }

  const showPausedToggle = document.getElementById('showPaused');

  function renderItems(items) {
    // --- NUEVO: FILTRO DE ESTADO ---
    const showPaused = showPausedToggle.checked;
    let filteredItems = items;
    
    if (!showPaused) {
      filteredItems = items.filter(i => i.status === 'active');
    }

    if (filteredItems.length === 0) {
      listingsBody.innerHTML = '<tr><td colspan="6" class="px-2 py-8 text-center text-slate-500 animate-pulse font-medium">No hay publicaciones activas para mostrar.</td></tr>';
      return;
    }

    // --- LOGICA DE AGRUPAMIENTO DINAMICA ---
    // Agrupamos por family_id + BaseTitle
    const groups = {};
    filteredItems.forEach(item => {
      const baseTitle = normalizeTitle(item.title);
      const gId = item.family_id ? `family-${item.family_id}-${baseTitle}` : `item-${item.id}`;
      
      if (!groups[gId]) {
        groups[gId] = { 
          id: gId, 
          familyId: item.family_id,
          baseTitle: baseTitle,
          items: [] 
        };
      }
      groups[gId].items.push(item);
    });

    let html = '';
    
    // Convertimos a array para procesar y ORDENAR:
    // Los grupos con más de 1 item van arriba. Los sueltos abajo.
    const groupList = Object.values(groups).sort((a, b) => {
      const aMultiple = a.items.length > 1 ? 1 : 0;
      const bMultiple = b.items.length > 1 ? 1 : 0;
      return bMultiple - aMultiple; // 1 (múltiple) viene antes que 0 (solo)
    });

    groupList.forEach(group => {
      const isMultiple = group.items.length > 1;

      if (!isMultiple) {
        // RENDER SINGLE ITEM (Suelto)
        html += renderRow(group.items[0], false);
      } else {
        // RENDER COLLAPSIBLE GROUP (Dropdown)
        const groupId = `collapse-${group.id.replace(/[^a-zA-Z0-9]/g, '-')}`;
        html += `
          <tr class="group-header-row bg-slate-50/80 dark:bg-slate-900 border-l-4 border-indigo-400 cursor-pointer hover:bg-slate-100 transition-colors" onclick="toggleGroup('${groupId}')">
            <td colspan="6" class="px-5 py-3 shadow-sm">
              <div class="flex items-center justify-between">
                <div class="flex items-center gap-3">
                  <div class="bg-indigo-100 dark:bg-indigo-900 p-1.5 rounded-lg text-indigo-600 dark:text-indigo-400">
                    <svg class="w-4 h-4 transform transition-transform duration-200" id="icon-${groupId}" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
                  </div>
                  <div>
                    <div class="text-sm font-bold text-slate-700 dark:text-slate-100">${group.baseTitle}</div>
                    <div class="text-[10px] text-slate-400 uppercase tracking-tighter">Pack / Familia • ${group.items.length} unidades diferentes</div>
                  </div>
                </div>
                <div class="flex items-center gap-4">
                   <div class="text-[10px] font-mono text-slate-400 bg-slate-100 dark:bg-slate-800 px-2 py-0.5 rounded">ID: ${group.familyId || group.items[0].id}</div>
                   <div class="text-xs font-bold text-indigo-500">Ver Packs</div>
                </div>
              </div>
            </td>
          </tr>
          <tr id="${groupId}" class="hidden group-content-rows">
            <td colspan="6" class="p-0">
               <div class="overflow-hidden">
                <table class="w-full border-separate border-spacing-0">
                  <tbody class="bg-white/50 dark:bg-slate-800/40 divide-y divide-slate-100 dark:divide-slate-700">
                    ${group.items.map(item => renderRow(item, true)).join('')}
                  </tbody>
                </table>
               </div>
            </td>
          </tr>
        `;
      }
    });

    listingsBody.innerHTML = html;
    attachEvents();
  }

  function renderRow(item, isChild) {
    const statusClass = {
      'active': 'bg-emerald-100 text-emerald-800 dark:bg-emerald-900/30 dark:text-emerald-400',
      'paused': 'bg-amber-100 text-amber-800 dark:bg-amber-900/30 dark:text-amber-400',
      'closed': 'bg-rose-100 text-rose-800 dark:bg-rose-900/30 dark:text-rose-400',
      'inactive': 'bg-rose-100 text-rose-800'
    }[item.status] || 'bg-slate-100 text-slate-800';

    const domId = item.variationId ? `${item.id}-${item.variationId}` : item.id;

    const localDataHtml = item.localData ? `
      <div class="flex items-center gap-2">
        <div class="flex-grow">
          <div class="text-[10px] font-bold text-emerald-600 dark:text-emerald-400 flex items-center gap-1 uppercase tracking-wider">
            <svg class="w-2.5 h-2.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
            Vinculado
          </div>
          <div class="text-[11px] text-slate-600 dark:text-slate-300 truncate max-w-48 font-medium">${item.localData.productName}</div>
        </div>
        <button class="text-slate-400 hover:text-indigo-500 unset-link-btn p-1 hover:bg-indigo-50 rounded transition-colors" data-dom-id="${domId}" title="Cambiar vínculo">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"></path></svg>
        </button>
      </div>
    ` : `
      <select class="form-select w-full text-[11px] py-1 h-8 product-select bg-slate-50 dark:bg-slate-900 border-slate-200 dark:border-slate-700 rounded shadow-sm focus:ring-indigo-500" data-dom-id="${domId}">
        <option value="">-- Vincular Producto --</option>
        ${allProducts.map(p => `<option value="${p.id}">${p.name} (${p.sku || 'N/A'})</option>`).join('')}
      </select>
    `;

    const typeBadge = item.variationId 
      ? `<span class="bg-indigo-50 dark:bg-indigo-900/40 text-indigo-600 dark:text-indigo-300 text-[9px] font-bold px-1.5 py-0.5 rounded ml-2 uppercase">Variante</span>`
      : (item.family_id ? `<span class="bg-slate-100 dark:bg-slate-700 text-slate-500 dark:text-slate-400 text-[9px] font-bold px-1.5 py-0.5 rounded ml-2 uppercase">Pack</span>` : '');

    const unitsAttr = item.attributes?.find(a => a.id === 'UNITS_PER_PACK');
    const unitsText = unitsAttr ? ` <span class="text-indigo-500 font-bold">(${unitsAttr.value_name}u)</span>` : '';

    return `
      <tr data-dom-id="${domId}" class="hover:bg-slate-50/50 dark:hover:bg-slate-700/5 transition-colors ${isChild ? 'bg-indigo-50/10' : ''}">
        <td class="px-2 first:pl-5 last:pr-5 py-3 whitespace-nowrap text-center">
          ${item.thumbnail ? `<img src="${item.thumbnail}" class="w-9 h-9 rounded shadow-sm object-cover mx-auto ring-1 ring-slate-200 dark:ring-slate-700" />` : '<div class="w-9 h-9 bg-slate-100 rounded mx-auto flex items-center justify-center text-slate-400 text-[9px]">?</div>'}
        </td>
        <td class="px-2 first:pl-5 last:pr-5 py-3 whitespace-normal">
          <div class="font-semibold text-slate-800 dark:text-slate-100 text-[13px]">
            ${item.title}${unitsText}
            ${typeBadge}
          </div>
          <div class="text-[10px] text-slate-500 mt-1 flex items-center gap-3">
            <span class="font-mono bg-slate-50 dark:bg-slate-900/50 border border-slate-100 dark:border-slate-800 px-1.5 py-0.5 rounded text-slate-400">${item.id}${item.variationId ? ` / ${item.variationId}` : ''}</span>
            <a href="${item.permalink}" target="_blank" class="text-indigo-500 hover:text-indigo-600 font-bold bg-indigo-50 dark:bg-indigo-900/20 px-2 py-0.5 rounded transition-colors">Ver en ML ↗</a>
            <span class="text-slate-700 dark:text-slate-300 font-bold text-xs ring-1 ring-slate-200 dark:ring-slate-700 px-2 py-0.5 rounded shadow-sm">$${item.price.toLocaleString('es-AR')}</span>
          </div>
        </td>
        <td class="px-2 first:pl-5 last:pr-5 py-3 whitespace-nowrap text-center">
          <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-[10px] font-bold uppercase ${statusClass}">${item.status}</span>
        </td>
        <td class="px-2 first:pl-5 last:pr-5 py-3 whitespace-nowrap">
          <div class="max-w-[200px]">${localDataHtml}</div>
        </td>
        <td class="px-2 first:pl-5 last:pr-5 py-3 whitespace-nowrap text-right">
          ${item.localData ? `<span class="font-bold text-slate-700 dark:text-slate-200 text-sm">$${Number(item.localData.inversionTotal).toLocaleString('es-AR', {minimumFractionDigits: 2})}</span>` : '<span class="text-xs text-slate-400">-</span>'}
        </td>
        <td class="px-2 first:pl-5 last:pr-5 py-3 whitespace-nowrap text-center">
          <div class="flex justify-center">
            ${item.localData ? `
              <button class="text-indigo-600 hover:text-white hover:bg-indigo-600 text-[10px] font-bold flex items-center gap-1.5 sync-price-btn p-1.5 border border-indigo-200 dark:border-indigo-800 rounded-lg transition-all" data-product-id="${item.localData.productId}">
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path></svg>
                Sync
              </button>
            ` : `
              <button class="bg-slate-800 dark:bg-indigo-600 text-white hover:bg-slate-900 dark:hover:bg-indigo-700 text-[10px] font-bold px-4 h-8 rounded-lg shadow-sm transition-all save-link-btn" data-dom-id="${domId}">
                Vincular
              </button>
            `}
          </div>
        </td>
      </tr>
    `;
  }

  window.toggleGroup = (id) => {
    const row = document.getElementById(id);
    const icon = document.getElementById(`icon-${id}`);
    if (row.classList.contains('hidden')) {
      row.classList.remove('hidden');
      icon.classList.add('rotate-180');
    } else {
      row.classList.add('hidden');
      icon.classList.remove('rotate-180');
    }
  };

  function attachEvents() {
    // Unset link
    document.querySelectorAll('.unset-link-btn').forEach(btn => {
      btn.onclick = () => {
        const domId = btn.getAttribute('data-dom-id');
        const item = allItems.find(i => (i.variationId ? `${i.id}-${i.variationId}` : i.id) === domId);
        if (item) {
          item.localData = null;
          renderItems(allItems);
        }
      };
    });

    // Save link
    document.querySelectorAll('.save-link-btn').forEach(btn => {
      btn.onclick = async () => {
        const domId = btn.getAttribute('data-dom-id');
        const item = allItems.find(i => (i.variationId ? `${i.id}-${i.variationId}` : i.id) === domId);
        
        const select = document.querySelector(`.product-select[data-dom-id="${domId}"]`);
        const productId = select.value;
        if (!productId) return alert('Selecciona un producto');

        btn.disabled = true;
        btn.innerText = 'Sync...';

        try {
          const res = await fetch('/api/meli/link-listing', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ 
              meliItemId: item.id, 
              meliVariationId: item.variationId,
              productId, 
              syncEnabled: true 
            })
          });
          const data = await res.json();
          if (data.success) {
            await loadListings();
          } else {
            alert('Error: ' + data.error);
            btn.disabled = false;
            btn.innerText = 'Vincular';
          }
        } catch (e) {
          alert('Error de red');
          btn.disabled = false;
          btn.innerText = 'Vincular';
        }
      };
    });

    // Sync Price
    document.querySelectorAll('.sync-price-btn').forEach(btn => {
      btn.onclick = async () => {
        const productId = btn.getAttribute('data-product-id');
        btn.disabled = true;
        const originalHtml = btn.innerHTML;
        btn.innerText = 'Syncing...';

        try {
          const res = await fetch('/api/meli/sync-price', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ productId })
          });
          const data = await res.json();
          if (data.success) {
            await loadListings();
          } else {
            alert('Error: ' + data.error);
            btn.disabled = false;
            btn.innerHTML = originalHtml;
          }
        } catch (e) {
          alert('Error de red');
          btn.disabled = false;
          btn.innerHTML = originalHtml;
        }
      };
    });
  }

  showPausedToggle.onchange = () => renderItems(allItems);

  let searchTimeout;
  searchInput.oninput = (e) => {
    const q = e.target.value;
    
    // Filtramos localmente sobre allItems (la data cruda del server)
    const localQ = q.toLowerCase();
    const filtered = allItems.filter(i => 
      i.title.toLowerCase().includes(localQ) || 
      i.id.toString().toLowerCase().includes(localQ) ||
      (i.localData && i.localData.productName.toLowerCase().includes(localQ))
    );
    // renderItems ya se encarga de filtrar por estado internamente
    renderItems(filtered);

    // Búsqueda en servidor con debounce
    clearTimeout(searchTimeout);
    if (q.length > 3) {
      searchTimeout = setTimeout(() => {
        loadListings(q);
      }, 1000);
    } else if (q.length === 0) {
       loadListings();
    }
  };

  btnReload.onclick = loadListings;

  // Initial load
  loadListings();
</script>
